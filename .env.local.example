# ─────────────────────────────────────────────────────────────
# SUPABASE — copy this file to .env.local and fill in values
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL
# Example: https://xyzabcdef.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anon/public key (safe for browser — respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (SECRET — server-side only, never expose to browser)
# Used for admin operations: creating orders, reading customers, etc.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
